#!/usr/bin/make -f
# -*- makefile -*-
# Sample debian/rules that uses debhelper.

.PHONY: override_dh_auto_configure

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

ifneq (,$(filter $(DEB_HOST_ARCH),amd64 i386 x32 kfreebsd-amd64 kfreebsd-i386 hurd-i386))
CFLAGS += -march=haswell -mtune=sapphirerapids -mprefer-avx128
endif

ifeq (,$(findstring noopt,$(DEB_BUILD_OPTIONS)))
CFLAGS += -fno-plt
endif

LDFLAGS += -Wl,-z,relro -Wl,-z,now -Wl,-O1 -Wl,--hash-style=both -Wl,--no-undefined -Wl,-z,noexecstack

%:
	dh $@ --parallel

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release
